JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
NODE_ENV=development
FRONTEND_URL="http://localhost:8080"

# Payment fees (charged to customer)
PAYMENT_CONVENIENCE_FEE_PERCENTAGE=2
PAYMENT_TAX_RATE=17.5
PAYMENT_TAX_RATE_KENYA=0

# Withdrawal fees (deducted from withdrawal amount)
WITHDRAWAL_MOBILE_MONEY_FEE_RATE=0.03
WITHDRAWAL_BANK_FEE_RATE=0.01
WITHDRAWAL_BANK_FIXED_FEE=700

# Paystack (Kenya)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
SYSTEM_SUBACCOUNT_CODE=

# Paychangu (Malawi)
PAYCHANGU_SECRET_KEY=
PAYCHANGU_PUBLIC_KEY=

BACKEND_URL=http://localhost:5000

PORT=5000
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
